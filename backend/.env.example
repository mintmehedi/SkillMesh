DATABASE_URL=postgresql://postgres:password@host:5432/postgres
DJANGO_SECRET_KEY=replace-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FF_ENABLE_TEXT_SIMILARITY=false
# Skill autocomplete: merge ESCO API results (https://esco.ec.europa.eu/). Disable if outbound HTTP is blocked.
ESCO_SKILLS_ENABLED=true
ESCO_SKILLS_TIMEOUT_SEC=3
ESCO_SKILLS_FETCH_LIMIT=15
OCR_SPACE_API_KEY=
# OCR.space: 1 or 2 (see OCR.space docs for engine differences)
OCR_SPACE_ENGINE=2
# true = may help tabular experience blocks; try if plain false misses columns
OCR_SPACE_IS_TABLE=false
OCR_SPACE_LANGUAGE=eng
# Phone photos: auto-rotate using OCR.space
OCR_SPACE_DETECT_ORIENTATION=true
# true = let OCR.space upscale (larger payload); usually off if we preprocess locally
OCR_SPACE_SCALE=false
OCR_SPACE_TIMEOUT_SEC=45
# Pillow pipeline before OCR (grayscale, autocontrast, resize). false = send original file
OCR_IMAGE_PREPROCESS=true
OCR_IMAGE_MAX_EDGE=2200
OCR_IMAGE_MIN_LONG_EDGE=1000
OCR_JPEG_QUALITY=90
# PDF text: pymupdf = reading-order sort (default auto + pypdf fallback if text too short)
PDF_EXTRACT_ENGINE=auto
PDF_FALLBACK_MIN_CHARS=80
# Optional: LLM work-experience extraction (OpenAI-compatible API). Requires RESUME_LLM_ENABLED=true.
RESUME_LLM_ENABLED=false
OPENAI_API_KEY=
# Alternative key name if you prefer not to use OPENAI_API_KEY
# LLM_API_KEY=
RESUME_LLM_MODEL=gpt-4o-mini
# Base URL without trailing path, e.g. https://api.openai.com/v1 or your proxy
RESUME_LLM_BASE_URL=https://api.openai.com/v1
RESUME_LLM_MAX_INPUT_CHARS=12000
RESUME_LLM_MAX_OUTPUT_TOKENS=4096
RESUME_LLM_TIMEOUT_SEC=45
# false if your OpenAI-compatible server rejects json response_format
RESUME_LLM_JSON_RESPONSE_FORMAT=true
