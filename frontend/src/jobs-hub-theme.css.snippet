/* Jobs hub: Seek-style layout (search + tabs + cards + sidebar), SkillMesh landing theme */
.jobsSeekPage {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: transparent;
  color: #0f172a;
}

.jobsSeekHero {
  position: relative;
  padding: 1.5rem clamp(1rem, 3vw, 2.5rem) 1.35rem;
  overflow: hidden;
  background:
    radial-gradient(900px 420px at 8% -30%, rgba(56, 189, 248, 0.32), transparent 58%),
    radial-gradient(780px 360px at 92% 0%, rgba(129, 140, 248, 0.28), transparent 55%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.72) 0%, rgba(238, 244, 255, 0.92) 100%);
  border-bottom: 1px solid rgba(148, 163, 184, 0.28);
}

.jobsSeekHero .heroGlow {
  opacity: 0.38;
}

.jobsSeekHero .heroMesh {
  opacity: 0.85;
  mask-image: radial-gradient(ellipse 85% 70% at 50% 40%, black 25%, transparent 100%);
}

.jobsSeekHeroKicker {
  margin: 0 0 0.85rem;
  text-align: left;
}

.jobsSeekHeroDecor {
  display: none;
}

.jobsSeekHeroInner {
  position: relative;
  z-index: 1;
  max-width: 1120px;
  margin: 0 auto;
}

.jobsSeekSearchGrid {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr) auto;
  gap: 0.75rem 1rem;
  align-items: end;
}

@media (max-width: 768px) {
  .jobsSeekSearchGrid {
    grid-template-columns: 1fr;
  }
}

.jobsSeekFieldBlock {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  min-width: 0;
}

.jobsSeekFieldLabel {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #1d4ed8;
}

.jobsSeekWhatRow {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(140px, 200px);
  gap: 0.55rem;
}

@media (max-width: 520px) {
  .jobsSeekWhatRow {
    grid-template-columns: 1fr;
  }
}

.jobsSeekInput,
.jobsSeekSelect {
  width: 100%;
  padding: 0.82rem 0.95rem;
  font-size: 0.96rem;
  border: 1px solid #bfdbfe;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.88);
  color: #0f172a;
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.06);
  transition: border-color 160ms ease, box-shadow 160ms ease;
}

.jobsSeekInput:focus,
.jobsSeekSelect:focus {
  outline: none;
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
}

.jobsSeekSelect {
  cursor: pointer;
}

.jobsSeekCtaWrap {
  display: flex;
  align-items: flex-end;
}

.jobsSeekCta {
  min-height: 48px;
  padding: 0 1.35rem;
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  border-radius: 14px;
  border: 1px solid transparent;
  color: #fff;
  cursor: pointer;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 50%, #7c3aed 100%);
  box-shadow: 0 12px 26px rgba(67, 56, 202, 0.28);
  transition: transform 180ms ease, box-shadow 180ms ease, filter 180ms ease;
}

.jobsSeekCta:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 16px 30px rgba(67, 56, 202, 0.33);
  filter: saturate(1.08);
}

.jobsSeekCta:disabled {
  opacity: 0.62;
  cursor: not-allowed;
  transform: none;
}

.jobsSeekMoreToggle {
  margin-top: 0.75rem;
  background: transparent;
  border: none;
  color: #4338ca;
  font-size: 0.86rem;
  font-weight: 600;
  cursor: pointer;
  text-decoration: underline;
  text-underline-offset: 3px;
  padding: 0;
}

.jobsSeekMorePanel {
  margin-top: 0.85rem;
  padding: 0.9rem 1rem;
  background: rgba(255, 255, 255, 0.78);
  border-radius: 16px;
  border: 1px solid rgba(148, 163, 184, 0.35);
  box-shadow: 0 10px 24px rgba(30, 64, 175, 0.08);
}

.jobsSeekMoreLabel {
  display: block;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  margin-bottom: 0.45rem;
}

.jobsSeekChipRow {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-bottom: 0.65rem;
}

.jobsSeekChip {
  padding: 0.38rem 0.75rem;
  font-size: 0.82rem;
  font-weight: 600;
  border-radius: 999px;
  border: 1px solid rgba(148, 163, 184, 0.4);
  background: rgba(255, 255, 255, 0.9);
  color: #475569;
  cursor: pointer;
  transition: border-color 140ms ease, background 140ms ease, color 140ms ease;
}

.jobsSeekChip:hover {
  border-color: rgba(99, 102, 241, 0.4);
}

.jobsSeekChipOn {
  background: rgba(99, 102, 241, 0.14);
  border-color: rgba(99, 102, 241, 0.5);
  color: #3730a3;
}

.jobsSeekLinkBtn {
  font-size: 0.84rem;
  font-weight: 700;
  color: #4338ca;
  background: transparent;
  border: none;
  text-decoration: underline;
  cursor: pointer;
  padding: 0;
}

.jobsSeekRecentBar {
  background: rgba(255, 255, 255, 0.62);
  backdrop-filter: blur(12px) saturate(140%);
  border-bottom: 1px solid rgba(148, 163, 184, 0.22);
  padding: 0.55rem clamp(1rem, 3vw, 2rem);
}

.jobsSeekRecentInner {
  max-width: 1120px;
  margin: 0 auto;
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  align-items: center;
}

.jobsSeekRecentChip {
  padding: 0.4rem 0.85rem;
  font-size: 0.86rem;
  font-weight: 600;
  color: #1e3a8a;
  background: rgba(255, 255, 255, 0.88);
  border: 1px solid rgba(99, 102, 241, 0.3);
  border-radius: 999px;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  cursor: pointer;
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.jobsSeekRecentChip:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 16px rgba(37, 99, 235, 0.14);
}

.jobsSeekFlash {
  max-width: 1120px;
  margin: 0.5rem auto 0;
  padding: 0 clamp(1rem, 3vw, 2rem);
}

.jobsSeekBody {
  flex: 1;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 320px;
  gap: 1.25rem;
  max-width: 1160px;
  margin: 0 auto;
  padding: 1.25rem clamp(1rem, 3vw, 2rem) 2rem;
  width: 100%;
  box-sizing: border-box;
  align-items: start;
}

@media (max-width: 960px) {
  .jobsSeekBody {
    grid-template-columns: 1fr;
  }
}

.jobsSeekMain {
  min-width: 0;
}

.jobsSeekTabs {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.25rem 1.25rem;
  border-bottom: 1px solid rgba(148, 163, 184, 0.35);
  margin-bottom: 0.65rem;
}

.jobsSeekTab {
  position: relative;
  padding: 0.5rem 0.15rem;
  font-size: 0.95rem;
  font-weight: 700;
  color: #64748b;
  background: transparent;
  border: none;
  cursor: pointer;
  margin-bottom: -1px;
}

.jobsSeekTab:hover:not(:disabled) {
  color: #1e293b;
}

.jobsSeekTab:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.jobsSeekTabOn {
  color: #1e293b;
}

.jobsSeekTabOn::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -1px;
  height: 3px;
  border-radius: 3px 3px 0 0;
  background: linear-gradient(90deg, #2563eb, #7c3aed 55%, #06b6d4);
}

.jobsSeekTabClear {
  margin-left: auto;
  font-size: 0.84rem;
  font-weight: 600;
  color: #4338ca;
  background: transparent;
  border: none;
  cursor: pointer;
  text-decoration: underline;
  padding: 0.5rem 0;
}

.jobsSeekListMeta {
  font-size: 0.84rem;
  color: #64748b;
  margin: 0 0 0.75rem;
}

.jobsSeekCardList {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
}

.jobsSeekEmpty {
  padding: 2rem 1rem;
  text-align: center;
  color: #64748b;
  font-size: 0.95rem;
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid rgba(148, 163, 184, 0.35);
  border-radius: 16px;
  box-shadow: 0 10px 24px rgba(30, 64, 175, 0.07);
}

.jobsSeekCard {
  background: rgba(255, 255, 255, 0.82);
  border: 1px solid rgba(148, 163, 184, 0.35);
  border-radius: 16px;
  padding: 1rem 1.15rem;
  cursor: pointer;
  transition: box-shadow 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
  text-align: left;
  box-shadow: 0 8px 22px rgba(30, 64, 175, 0.07);
}

.jobsSeekCard:hover {
  border-color: rgba(99, 102, 241, 0.35);
  box-shadow: 0 12px 28px rgba(30, 64, 175, 0.11);
  transform: translateY(-1px);
}

.jobsSeekCardActive {
  border-color: rgba(79, 70, 229, 0.45);
  box-shadow: 0 14px 32px rgba(67, 56, 202, 0.14);
}

.jobsSeekCard:focus {
  outline: none;
}

.jobsSeekCard:focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.25);
}

.jobsSeekCardTop {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: flex-start;
}

.jobsSeekCardText {
  min-width: 0;
}

.jobsSeekCardTitle {
  margin: 0 0 0.25rem;
  font-size: 1.05rem;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.25;
  letter-spacing: -0.02em;
}

.jobsSeekCardCompany {
  margin: 0 0 0.45rem;
  font-size: 0.9rem;
  color: #475569;
}

.jobsSeekCardBadges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-bottom: 0.45rem;
}

.jobsSeekBadge {
  font-size: 0.68rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 0.2rem 0.45rem;
  border-radius: 8px;
}

.jobsSeekBadgeRec {
  background: rgba(99, 102, 241, 0.14);
  color: #3730a3;
  border: 1px solid rgba(99, 102, 241, 0.28);
}

.jobsSeekBadgeNew {
  background: rgba(224, 242, 254, 0.95);
  color: #0369a1;
  border: 1px solid rgba(56, 189, 248, 0.35);
}

.jobsSeekBadgeApp {
  background: rgba(220, 252, 231, 0.95);
  color: #166534;
  border: 1px solid rgba(34, 197, 94, 0.3);
}

.jobsSeekCardFacts {
  margin: 0;
  padding: 0 0 0 1.1rem;
  font-size: 0.84rem;
  color: #475569;
  line-height: 1.5;
}

.jobsSeekCardLogo {
  flex-shrink: 0;
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: grid;
  place-items: center;
  font-weight: 800;
  font-size: 1.05rem;
  color: #3730a3;
  background: linear-gradient(145deg, rgba(224, 231, 255, 0.95), rgba(199, 210, 254, 0.75));
  border: 1px solid rgba(99, 102, 241, 0.22);
}

.jobsSeekCardBottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 0.75rem;
  padding-top: 0.65rem;
  border-top: 1px solid rgba(226, 232, 240, 0.95);
}

.jobsSeekCardPosted {
  font-size: 0.8rem;
  color: #64748b;
}

.jobsSeekCardActions {
  display: flex;
  gap: 0.2rem;
}

.jobsSeekIconBtn {
  display: grid;
  place-items: center;
  width: 40px;
  height: 40px;
  border: none;
  border-radius: 10px;
  background: transparent;
  color: #64748b;
  cursor: pointer;
  transition: background 0.12s ease, color 0.12s ease;
}

.jobsSeekIconBtn:hover {
  background: rgba(238, 242, 255, 0.95);
  color: #4338ca;
}

.jobsSeekIconBtnOn {
  color: #4f46e5;
}

.jobsSeekAside {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  position: sticky;
  top: 0.75rem;
}

@media (max-width: 960px) {
  .jobsSeekAside {
    position: static;
  }
}

.jobsSeekAsideCard {
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid rgba(148, 163, 184, 0.35);
  border-radius: 16px;
  padding: 1rem 1.1rem;
  box-shadow: 0 8px 22px rgba(30, 64, 175, 0.07);
}

.jobsSeekAsideMuted {
  background: rgba(248, 250, 252, 0.85);
}

.jobsSeekAsideTitle {
  margin: 0 0 0.4rem;
  font-size: 0.92rem;
  font-weight: 800;
  color: #0f172a;
  letter-spacing: -0.01em;
}

.jobsSeekAsideText {
  margin: 0;
  font-size: 0.86rem;
  line-height: 1.45;
  color: #64748b;
}

.jobsSeekAsideLink {
  display: inline-block;
  margin-top: 0.55rem;
  font-size: 0.88rem;
  font-weight: 700;
  color: #4338ca;
  text-decoration: none;
}

.jobsSeekAsideLink:hover {
  text-decoration: underline;
}

.jobsSeekDetail {
  background: rgba(255, 255, 255, 0.88);
  border: 1px solid rgba(148, 163, 184, 0.35);
  border-radius: 16px;
  padding: 1rem 1.15rem;
  box-shadow: 0 10px 26px rgba(30, 64, 175, 0.09);
}

.jobsSeekDetailEyebrow {
  margin: 0 0 0.35rem;
  font-size: 0.7rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #64748b;
}

.jobsSeekDetailTitle {
  margin: 0 0 0.25rem;
  font-size: 1.05rem;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.25;
  letter-spacing: -0.02em;
}

.jobsSeekDetailSub {
  margin: 0 0 0.65rem;
  font-size: 0.9rem;
  color: #475569;
}

.jobsSeekDetailTags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-bottom: 0.75rem;
}

.jobsSeekDetailTags span {
  font-size: 0.78rem;
  font-weight: 600;
  padding: 0.28rem 0.55rem;
  background: rgba(241, 245, 249, 0.95);
  border: 1px solid rgba(148, 163, 184, 0.3);
  border-radius: 999px;
  color: #475569;
}

.jobsSeekDetailMatch {
  margin-bottom: 0.75rem;
  padding: 0.75rem 0.85rem;
  background: linear-gradient(135deg, rgba(238, 242, 255, 0.95), rgba(224, 231, 255, 0.55));
  border-radius: 14px;
  border: 1px solid rgba(99, 102, 241, 0.22);
}

.jobsSeekDetailMatchTop {
  display: flex;
  justify-content: space-between;
  font-size: 0.84rem;
  margin-bottom: 0.35rem;
  color: #475569;
}

.jobsSeekDetailMatchTop strong {
  color: #312e81;
}

.jobsSeekMatchTrack {
  height: 8px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.65);
  overflow: hidden;
  border: 1px solid rgba(99, 102, 241, 0.12);
}

.jobsSeekMatchFill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #2563eb, #7c3aed 55%, #06b6d4);
  transition: width 0.25s ease;
}

.jobsSeekSkillRow {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-bottom: 0.75rem;
}

.jobsSeekSkillTag {
  font-size: 0.78rem;
  font-weight: 600;
  padding: 0.28rem 0.5rem;
  background: rgba(238, 242, 255, 0.9);
  border: 1px solid rgba(129, 140, 248, 0.35);
  border-radius: 999px;
  color: #3730a3;
}

.jobsSeekDesc {
  font-size: 0.88rem;
  line-height: 1.55;
  color: #334155;
  white-space: pre-wrap;
  max-height: 220px;
  overflow-y: auto;
  margin-bottom: 1rem;
  padding: 0.75rem 0.85rem;
  border-radius: 12px;
  background: rgba(248, 250, 252, 0.75);
  border: 1px solid rgba(226, 232, 240, 0.95);
}

.jobsSeekApply {
  width: 100%;
  padding: 0.82rem 1rem;
  font-size: 0.95rem;
  font-weight: 700;
  border-radius: 14px;
  border: 1px solid transparent;
  color: #fff;
  cursor: pointer;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 50%, #7c3aed 100%);
  box-shadow: 0 10px 24px rgba(67, 56, 202, 0.26);
  transition: transform 180ms ease, box-shadow 180ms ease;
}

.jobsSeekApply:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 28px rgba(67, 56, 202, 0.32);
}

.jobsSeekAppliedNote {
  margin: 0;
  font-size: 0.88rem;
  font-weight: 600;
  color: #166534;
}

.jobsSeekAppMini {
  list-style: none;
  margin: 0.5rem 0 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.jobsSeekAppMini li {
  padding-bottom: 0.45rem;
  border-bottom: 1px solid rgba(226, 232, 240, 0.95);
}

.jobsSeekAppMini li:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.jobsSeekAppMiniTitle {
  display: block;
  font-size: 0.84rem;
  font-weight: 700;
  color: #0f172a;
}

.jobsSeekAppMiniMeta {
  font-size: 0.78rem;
  color: #64748b;
}

.jobsSeekFooter {
  text-align: center;
  padding: 0.85rem;
  font-size: 0.82rem;
  color: #64748b;
  border-top: 1px solid rgba(148, 163, 184, 0.25);
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(8px);
}
